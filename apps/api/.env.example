NODE_ENV=development
PORT=4000
LOG_LEVEL=info

WEB_APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/timewell?appName=Cluster0
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-xxxxxxxxxx
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-yyyyyyyyyy
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

BCRYPT_COST=12

COOKIE_DOMAIN=
COOKIE_SECURE=false

SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Timewell

TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15555550100

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET=timewell-media
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
